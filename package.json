{
  "name": "vue-spring-bottom-sheet-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "workspaceRelease": {
    "npmRelease": true,
    "changelogCommit": true,
    "release": {
      "branches": [
        "master",
        {
          "name": "next",
          "prerelease": true
        },
        {
          "name": "beta",
          "prerelease": true
        },
        {
          "name": "alpha",
          "prerelease": true
        }
      ]
    },
    "extendsReleaseRules": [
      {
        "type": "docs",
        "scope": "README",
        "release": "patch"
      }
    ],
    "tagFormat": "v${version}",
    "perPackageConfig": {
      "apps/**": {
        "skip": true
      }
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "format": "turbo format",
    "start": "node apps/playground/.output/server/index.mjs",
    "semantic-release": "semantic-release-npm-workspaces-monorepo",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "vitepress build apps/docs",
    "docs:preview": "vitepress preview apps/docs"
  },
  "dependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^25.0.2"
  },
  "devDependencies": {
    "semantic-release-npm-workspaces-monorepo": "^3.2.1",
    "turbo": "^2.8.1",
    "vitepress": "^2.0.0-alpha.16",
    "vitepress-plugin-npm-commands": "^0.8.1",
    "vitepress-plugin-tabs": "^0.7.3",
    "vue": "^3.5.28"
  }
}
