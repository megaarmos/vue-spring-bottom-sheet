{
  "name": "@opekunov/vue-spring-bottom-sheet",
  "description": "Modern and Performant Bottom Sheet for Vue.js",
  "keywords": [
    "animation",
    "bottom-drawer",
    "bottom-sheet",
    "bottomsheet",
    "dialog",
    "drag-drop",
    "draggableview",
    "drawer",
    "gesture-control",
    "modal",
    "motion",
    "overlay",
    "popup",
    "vue",
    "sheet",
    "typescript"
  ],
  "author": "Arion Paul",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/megaarmos/vue-spring-bottom-sheet.git"
  },
  "homepage": "https://vue-spring-bottom-sheet.douxcode.com/",
  "bugs": {
    "url": "https://github.com/megaarmos/vue-spring-bottom-sheet/issues"
  },
  "private": false,
  "version": "3.0.0-next.5",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./dist/style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    }
  },
  "main": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/",
    "release": "cp ../../README.md . && bun run build && bun run type-check && npm publish --access public",
    "prepublishOnly": "cp ../../README.md . && bun run build && bun run type-check"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "@vueuse/integrations": "^14.1.0",
    "focus-trap": "^7.8.0",
    "remeda": "^2.33.3",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "ajv": "^8.17.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "happy-dom": "^20.8.9",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
